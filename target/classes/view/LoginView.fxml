<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.LoginViewController" spacing="15" style="-fx-padding: 40;" stylesheets="@LoginView.css">
    <Label text="🔐 FreelanceHub Login" style="-fx-font-size: 28; -fx-text-fill: #0EA5E9; -fx-alignment: center;"/>
    <TextField fx:id="emailField" promptText="Email" style="-fx-font-size: 14;"/>
    <PasswordField fx:id="senhaField" promptText="Senha" style="-fx-font-size: 14;"/>
    <Button fx:id="loginButton" text="Entrar" style="-fx-font-size: 14; -fx-padding: 10;"/>
    <Button fx:id="cancelButton" text="Cancelar" style="-fx-font-size: 14; -fx-padding: 10;"/>
    <Label fx:id="erroLabel" style="-fx-font-size: 12;"/>
</VBox>